<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A237E"
                android:centerColor="#283593"
                android:endColor="#3949AB"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>
    <!-- Wave overlay -->
    <item>
        <vector
            android:width="100dp"
            android:height="40dp"
            android:viewportWidth="100"
            android:viewportHeight="40">
            <path
                android:fillColor="#15FFFFFF"
                android:pathData="M0,15 C20,5 40,25 60,15 C80,5 90,20 100,12 L100,40 L0,40 Z" />
        </vector>
    </item>
</layer-list>