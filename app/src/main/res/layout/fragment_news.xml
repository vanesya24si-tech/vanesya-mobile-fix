<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header bar -->
    <View
        android:id="@+id/newsHeaderBackground"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/primary_lembaga"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNewsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Berita &amp; Informasi"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/newsHeaderBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/newsHeaderBackground" />

    <!-- TabLayout for news source: Online vs Favorite -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutNews"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_lembaga"
        app:layout_constraintTop_toBottomOf="@+id/newsHeaderBackground"
        app:tabIndicatorColor="@color/accent_lembaga"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="#BDBDBD">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berita Publik" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berita Favorit" />
    </com.google.android.material.tabs.TabLayout>

    <!-- ChipGroup for category filter -->
    <HorizontalScrollView
        android:id="@+id/newsCategoryScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintTop_toBottomOf="@+id/tabLayoutNews">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupNews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipGov"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pemerintahan"
                android:checked="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEdu"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendidikan"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHealth"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kesehatan"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipUmkm"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UMKM"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAgri"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pertanian"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Swipe Refresh Layout containing RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshNews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/newsCategoryScroll">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNews"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            tools:listitem="@layout/item_news" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/pbNews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/newsCategoryScroll" />

</androidx.constraintlayout.widget.ConstraintLayout>
